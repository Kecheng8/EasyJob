# Database
DATABASE_URL=postgresql://localhost/easyjob

# LLM (the agent runtime). Defaults to claude-opus-4-8.
ANTHROPIC_API_KEY=sk-ant-...
EASYJOB_MODEL=claude-opus-4-8

# Web search MCP (Exa). Swap for Tavily/Brave by editing web_search_server.py.
EXA_API_KEY=...

# LinkedIn/Indeed MCP — a compliant data partner. Left unset, that server
# returns empty results gracefully.
JOBS_PARTNER_API=
JOBS_PARTNER_KEY=
